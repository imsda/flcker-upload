TIMEZONE=America/Chicago
POLL_INTERVAL_SECONDS=120
DATABASE_PATH=/var/lib/drive-to-flickr/state.sqlite
STAGING_DIR=/var/lib/drive-to-flickr/staging
GOOGLE_CREDENTIALS_FILE=/etc/drive-to-flickr/google-client.json
GOOGLE_TOKEN_FILE=/etc/drive-to-flickr/google-token.json
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id
GOOGLE_CALENDAR_ID=your-calendar-id@example.com
FLICKR_API_KEY=your-flickr-api-key
FLICKR_API_SECRET=your-flickr-api-secret
FLICKR_OAUTH_TOKEN=your-flickr-oauth-token
FLICKR_OAUTH_TOKEN_SECRET=your-flickr-oauth-token-secret
BUFFER_BEFORE_MINUTES=0
BUFFER_AFTER_MINUTES=0
REQUIRE_FLICKR_MARKER=false
NO_EVENT_ACTION=unassigned
UNASSIGNED_ALBUM=Unassigned Uploads
DRIVE_SUCCESS_ACTION=leave
DRIVE_SUCCESS_FOLDER=
DRIVE_FAILED_FOLDER=
MINIMUM_FILE_AGE_SECONDS=60
FLICKR_DEFAULT_PRIVACY=private
GLOBAL_TAGS=
LOG_LEVEL=INFO
MAX_ATTEMPTS=5
